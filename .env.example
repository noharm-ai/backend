# Application
ENV=development                         # development | production | test
SECRET_KEY=change-me                    # JWT signing key
ENCRYPTION_KEY=                         # Fernet key for sensitive data at rest (optional)
API_KEY=                                # Internal API authentication key
APP_URL=                                # Public frontend URL
APP_DOMAIN=localhost                    # Cookie domain
SELF_API_URL=                           # URL this API uses to call itself

# Database
POTGRESQL_CONNECTION_STRING=postgresql://postgres@localhost/noharm
REPORT_CONNECTION_STRING=postgresql://postgres@localhost/noharm   # Separate reporting DB

# JWT expiry
JWT_ACCESS_TOKEN_EXPIRES=20             # Minutes
JWT_REFRESH_TOKEN_EXPIRES=30            # Days

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email
MAIL_HOST=localhost
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=
MAIL_SENDER=noreply@example.com

# AWS — NiFi / data pipeline
NIFI_BUCKET_NAME=
NIFI_SQS_QUEUE_REGION=
NIFI_LOG_GROUP_NAME=

# AWS — Cache bucket
CACHE_BUCKET_NAME=
CACHE_BUCKET_ID=
CACHE_BUCKET_KEY=

# AWS — Lambda functions
SCORES_FUNCTION_NAME=
BACKEND_FUNCTION_NAME=

# ML inference service
SERVICE_INFERENCE=                      # URL of the external inference service

# Odoo ERP integration
ODOO_API_URL=
ODOO_API_DB=
ODOO_API_USER=
ODOO_API_KEY=

# OpenAI / Azure OpenAI (LLM features)
OPEN_AI_API_ENDPOINT=
OPEN_AI_API_KEY=
OPEN_AI_API_VERSION=
OPEN_AI_API_MODEL=

# Maritaca (Brazilian LLM)
MARITACA_API_KEY=

# Feature flags
FEATURE_CONCILIATION_ALGORITHM=FUZZY   # FUZZY | <other algorithm>
